{
  "name": "sonari",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint apps packages --max-warnings 0",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:store": "pnpm --filter @sonari/store dev",
    "dev:admin": "pnpm --filter @sonari/admin dev",
    "dev:api": "pnpm --filter @sonari/api dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@sonari/config": "workspace:*",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.107.0"
  }
}
