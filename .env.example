# Copy to `.env` at repo root for local tooling. Apps also have their own `.env.example`.
# Never commit real secrets.

# --- Supabase (Mumbai / ap-south-1) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# --- API ---
PORT=3001
HOST=0.0.0.0
REDIS_URL=

# --- Sentry ---
SENTRY_DSN_API=
SENTRY_DSN_STORE=
SENTRY_DSN_ADMIN=

# --- Frontend (also set in apps/store/.env and apps/admin/.env) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:3001
VITE_SENTRY_DSN=
